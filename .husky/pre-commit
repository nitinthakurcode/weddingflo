#!/usr/bin/env sh

# Pre-commit Security Checks
# Security February 2026
#
# This hook runs security checks before allowing commits.
# NOTE: Husky v9 runs hooks with "sh -e" regardless of shebang,
# so this script must be POSIX sh compatible (no bash arrays).

echo "Running pre-commit security checks..."

# Check 1: npm audit for high+ vulnerabilities
echo "Checking for npm vulnerabilities..."
if ! npm audit --audit-level=high --omit=dev 2>/dev/null; then
  echo ""
  echo "ERROR: npm audit found high or critical vulnerabilities."
  echo "Please run 'npm audit fix' or update the affected packages."
  echo ""
  echo "To skip this check (NOT RECOMMENDED), use:"
  echo "  git commit --no-verify"
  exit 1
fi

# Check 2: Secret detection in staged files
echo "Checking for secrets in staged files..."

# Combined regex pattern for common secrets (pipe-separated)
SECRET_PATTERN='AKIA[0-9A-Z]{16}|sk_live_[a-zA-Z0-9]{24,}|sk_test_[a-zA-Z0-9]{24,}|ghp_[a-zA-Z0-9]{36}|gho_[a-zA-Z0-9]{36}|ghu_[a-zA-Z0-9]{36}|ghs_[a-zA-Z0-9]{36}|github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}|xox[baprs]-[a-zA-Z0-9-]+|sq0csp-[a-zA-Z0-9_-]{43}|sq0atp-[a-zA-Z0-9_-]{22}|BEGIN RSA PRIVATE KEY|BEGIN OPENSSH PRIVATE KEY|BEGIN PGP PRIVATE KEY|SG\.[a-zA-Z0-9]{22}\.[a-zA-Z0-9]{43}|rk_live_[a-zA-Z0-9]{24,}'

# Get staged files (excluding binaries, lock files, and hook scripts)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v -E '\.(png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$' | grep -v 'package-lock.json' | grep -v '.husky/')

# Check each staged file for secrets
SECRETS_FOUND=0
for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    MATCHES=$(grep -nE "$SECRET_PATTERN" "$file" 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
      echo "WARNING: Potential secret found in $file:"
      echo "$MATCHES"
      SECRETS_FOUND=1
    fi
  fi
done

if [ "$SECRETS_FOUND" -eq 1 ]; then
  echo ""
  echo "ERROR: Potential secrets detected in staged files."
  echo "Please review and remove any sensitive data before committing."
  echo ""
  echo "If this is a false positive, you can skip this check with:"
  echo "  git commit --no-verify"
  echo ""
  echo "NOTE: Using --no-verify skips ALL pre-commit hooks. Use with caution."
  exit 1
fi

# Check 3: Verify no .env files are being committed
ENV_FILES=$(git diff --cached --name-only | grep -E '\.env(\..+)?$' | grep -v '\.example' || true)
if [ -n "$ENV_FILES" ]; then
  echo ""
  echo "ERROR: Attempting to commit .env files:"
  echo "$ENV_FILES"
  echo ""
  echo "Remove these files from the commit:"
  echo "  git reset HEAD <filename>"
  exit 1
fi

echo "Pre-commit security checks passed!"

# Check 4: Code-quality gate (types + lint + fast test suite)
# These enforce the invariants that prior manual audits had to catch by hand.
# The vitest suite is fast (~2s); tsc is the slow step but worth it pre-commit.
# Skip with `git commit --no-verify` only in genuine emergencies.
echo "Running type check (tsc --noEmit)..."
if ! npm run --silent type-check; then
  echo ""
  echo "ERROR: TypeScript type check failed. Fix type errors before committing."
  exit 1
fi

echo "Running ESLint..."
if ! npm run --silent lint; then
  echo ""
  echo "ERROR: ESLint failed. Fix lint errors before committing."
  exit 1
fi

echo "Running unit test suite (vitest)..."
if ! npm run --silent test:unit; then
  echo ""
  echo "ERROR: Unit tests failed. Fix failing tests before committing."
  exit 1
fi

echo "All pre-commit checks passed!"
