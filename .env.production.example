# Database (Hetzner PostgreSQL - Production)
DATABASE_URL=postgresql://user:password@host:5432/weddingflo

# BetterAuth (Production)
BETTER_AUTH_SECRET=your_32_character_secret_key_here
BETTER_AUTH_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Google OAuth (Production)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI: env-driven multi-provider failover (any OpenAI-compatible provider plugs in).
# Order via AI_PROVIDER_ORDER (csv); only providers with a key activate.
# Strategy: PRIVACY-SAFE (no training on prompts + Zero Data Retention, US/EU host)
# and FREE-FIRST. Default order: groq,cerebras,openai.
#   groq     = primary, free tier, US/GCP + ZDR, ~500 tok/s, strong tool-calling.
#   cerebras = secondary, free 1M tokens/day, never stores/logs/reuses prompts.
#   openai   = PAID backstop, fires only when both free providers fail (≈ $0).
# IMPORTANT: enable Zero Data Retention in each provider's data-controls.
AI_PROVIDER_ORDER=groq,cerebras,openai
# Groq (primary, free) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FAST_MODEL=openai/gpt-oss-20b
# Cerebras (secondary, free) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-32b
# OpenAI (paid backstop) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional extra providers (activate by adding a key):
# OPENROUTER_API_KEY=      # paid + ZDR config only (free OpenRouter models train on data)
# GEMINI_API_KEY=          # PAID/Vertex key only — the free Gemini tier trains on prompts
# DEEPSEEK_API_KEY=        # NOT privacy-safe (China-hosted, trains by default) — avoid for PII
AI_MAX_TOKENS=2000

# Stripe (Live Mode)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Resend (Production)
RESEND_API_KEY=re_...

# Twilio (Production)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
TWILIO_WHATSAPP_NUMBER=whatsapp:+1...

# Firebase (Production) - For Push Notifications
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=...firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=...
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=...appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
NEXT_PUBLIC_FIREBASE_APP_ID=1:...:web:...
NEXT_PUBLIC_FIREBASE_VAPID_KEY=...
FIREBASE_ADMIN_PROJECT_ID=...
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-...@....iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Sentry (Production)
NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=...
SENTRY_PROJECT=weddingflo

# PostHog (Production)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Token Encryption (Phase 2 Security) - AES-256-GCM key for OAuth tokens at rest
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Redis (Production) - realtime sync pub/sub + rate limiting
# Self-hosted via the `srh` (Serverless Redis HTTP) service in docker-compose.yml.
# The app uses the @upstash/redis REST client, so the URL points at SRH, not at
# Redis directly. Inside the Dokploy/Compose network use the service name:
#   UPSTASH_REDIS_REST_URL=http://srh:80
# The token MUST equal SRH_TOKEN set on the `srh` service. Generate once with:
#   openssl rand -hex 32
UPSTASH_REDIS_REST_URL=http://srh:80
UPSTASH_REDIS_REST_TOKEN=
# Same value, passed to the SRH container (see docker-compose.yml `srh.environment`):
SRH_TOKEN=
# Used by the daily redis-keepalive cron auth (Authorization: Bearer $CRON_SECRET)
CRON_SECRET=

# Storage (Cloudflare R2)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=weddingflo-storage
CLOUDFLARE_ACCOUNT_ID=...

# App Config
NODE_ENV=production
